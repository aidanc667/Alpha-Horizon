# ─────────────────────────────────────────────────────────────────────────────
#  Alpha Horizon — Environment Variables
#  NEVER commit .env.local to git. This file stays on the server only.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Clerk Authentication ────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ─── Neon Postgres ───────────────────────────────────────────────────────────
# Get this from https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://...

# ─── Gemini AI ───────────────────────────────────────────────────────────────
# Your Gemini API key — used ONLY in server-side /api routes, never exposed to browser
GEMINI_API_KEY=...

# Alias for backward compatibility with original AI Financial Planner
API_KEY=...

# Optional: set to "production" for optimized builds
NODE_ENV=development
