# ─────────────────────────────────────────────────────────────────────────────
#  Alpha Horizon — Environment Variables
#  NEVER commit .env.local to git. This file stays on the server only.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Clerk Authentication ────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ─── Neon Postgres ───────────────────────────────────────────────────────────
# Get this from https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://...

# ─── Polygon.io ──────────────────────────────────────────────────────────────
# Real-time stock/ETF prices used by Silas (Portfolio Intelligence AI).
# Massive plan recommended. Get key at https://polygon.io/dashboard
POLYGON_API_KEY=

# ─── FRED (Federal Reserve Economic Data) ────────────────────────────────────
# Free API key at https://fred.stlouisfed.org/docs/api/api_key.html
# Used by Agent 2 for live Treasury yields, inflation, and credit spread data.
# Without this key, Agent 2 falls back to static January 2026 CMA estimates.
FRED_API_KEY=

# ─── Gemini AI ───────────────────────────────────────────────────────────────
# Your Gemini API key — used ONLY in server-side /api routes, never exposed to browser
GEMINI_API_KEY=...

# Alias for backward compatibility with original AI Financial Planner
API_KEY=...

# Optional: set to "production" for optimized builds
NODE_ENV=development

# ─── OpenTelemetry Tracing ────────────────────────────────────────────────────
# Traces sent to this OTLP HTTP endpoint (appends /v1/traces automatically).
# Start the local Tempo stack first: docker compose up -d
# Then view traces in Grafana at http://localhost:3100 → Explore → Tempo
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=alpha-horizon
